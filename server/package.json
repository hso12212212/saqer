{
  "name": "al-saqer-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend API for Al Saqer store (Express + PostgreSQL)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
